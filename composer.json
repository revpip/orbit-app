{
  "name": "revpip/orbit-app",
  "description": "Pure PHP 8.4 web application for ORBIT.",
  "type": "project",
  "require": {
    "php": ">=8.4"
  },
  "autoload": {
    "psr-4": {
      "Orbit\\": "app/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!file_exists('.env')) copy('.env.example', '.env');\""
    ]
  }
}
